# Backend deployment/local environment variables

# Database (MySQL)
DB_URL=jdbc:mysql://<host>:3306/<database>?useSSL=true&allowPublicKeyRetrieval=true&serverTimezone=UTC
DB_USERNAME=<db_user>
DB_PASSWORD=<db_password>

# JWT/Admin
JWT_SECRET=<base64_encoded_secret_at_least_32_bytes>
ADMIN_ID=superadmin
ADMIN_PASSWORD=<strong_password>

# Mail
GMAIL_USERNAME=<gmail_address>
GMAIL_APP_PASSWORD=<gmail_app_password>

# App URL and uploads
APP_PUBLIC_BASE_URL=https://<your-render-backend>.onrender.com
APP_UPLOAD_DIR=/var/data/uploads
APP_STORAGE_TYPE=local

# Cloudinary (required only when APP_STORAGE_TYPE=cloudinary)
CLOUDINARY_CLOUD_NAME=<cloud_name>
CLOUDINARY_API_KEY=<api_key>
CLOUDINARY_API_SECRET=<api_secret>
CLOUDINARY_FOLDER=food-distribution/food-images

# Food image ML validation (Hugging Face)
APP_FOOD_IMAGE_VALIDATION_ENABLED=true
APP_FOOD_IMAGE_VALIDATION_FAIL_OPEN=false
APP_FOOD_IMAGE_VALIDATION_THRESHOLD=0.18
APP_FOOD_IMAGE_VALIDATION_HF_URL=https://api-inference.huggingface.co/models/microsoft/resnet-50
APP_FOOD_IMAGE_VALIDATION_HF_API_TOKEN=<optional_huggingface_token>

# Optional
PORT=8080
JPA_SHOW_SQL=false
